{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://open-autonomy.dev/schema/GeneratedManifest.json",
  "title": "Open Autonomy GeneratedManifest",
  "$ref": "#/$defs/GeneratedManifest",
  "$defs": {
    "GeneratedManifest": {
      "type": "object",
      "properties": {
        "schema": {
          "const": "open-autonomy.generated.v1"
        },
        "files": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "schema",
        "files"
      ],
      "additionalProperties": false
    }
  }
}
