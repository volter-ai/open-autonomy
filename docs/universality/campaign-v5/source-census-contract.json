{
  "schema": "open-autonomy.source-census-contract.v1",
  "id": "oa-source-census-2026-v5",
  "campaignId": "organization-universality-2026-v5",
  "domainPredicate": "runtime-autonomously-executes-software-work-or-coordinates-two-or-more-agent-roles-sessions-or-work-items-toward-software-work",
  "adoption": {
    "provider": "github",
    "metric": "stargazers_count",
    "threshold": 1000,
    "includeForks": true,
    "includeArchived": true
  },
  "enumeration": {
    "rootQuery": "stars:>=1000 fork:true",
    "pageSize": 100,
    "sort": "stars",
    "order": "desc",
    "traversal": "depth-first-low-range-first",
    "starPartition": {
      "lowerBound": 1000,
      "upperBoundSource": "root-page-1-maximum-stargazers-count",
      "interval": "closed-integer",
      "split": "lo-to-floor-midpoint-and-floor-midpoint-plus-one-to-hi"
    },
    "overflowPartition": {
      "field": "created",
      "precision": "utc-day",
      "lowerBound": "2007-10-29",
      "upperBoundSource": "utc-date-of-pass-started-at",
      "interval": "closed-day",
      "split": "lo-to-floor-midpoint-and-floor-midpoint-plus-one-to-hi",
      "terminal": "single-utc-day",
      "unpartitionable": "invalidate-campaign"
    }
  },
  "completion": {
    "pass": {
      "rootRequest": "per-page-1-page-1-before-partitioning",
      "leafCountRequest": "per-page-1-page-1",
      "leafPageRequests": "pages-1-through-ceiling-total-over-100",
      "maximumTotalAttempts": 3,
      "retryableFailures": [
        "transport-failure",
        "non-rate-limit-non-200",
        "malformed-response-schema",
        "incomplete-results-true",
        "leaf-total-count-drift"
      ],
      "retryTransition": "retain-failed-evidence-discard-pass-and-restart-from-root",
      "rateLimitTransition": "on-403-with-valid-x-ratelimit-reset-retry-same-request-until-cutoff-without-consuming-pass-attempt",
      "immediateInvalidations": [
        "unpartitionable-overflow-leaf",
        "accepted-response-at-or-after-cutoff",
        "raw-body-digest-mismatch",
        "node-id-alias"
      ]
    },
    "leaf": {
      "maximumResults": 1000,
      "incompleteResults": "must-be-false",
      "totalCount": "equal-on-count-response-and-every-page",
      "pageCoverage": "one-through-ceiling-total-count-over-page-size"
    },
    "convergence": {
      "consecutivePasses": 2,
      "tupleFields": [
        "node_id",
        "full_name",
        "stargazers_count",
        "fork",
        "archived"
      ],
      "tupleEncoding": "canonical-json-of-lexicographically-node-id-sorted-tuples",
      "leafCountEncoding": "canonical-json-map-from-canonical-range-to-count",
      "requireIdenticalLeafCounts": true,
      "unstableLeaf": "retryable-leaf-total-count-drift"
    },
    "populationInstant": "completed-at-of-second-converged-pass"
  },
  "classification": {
    "samplingFrame": "unique-node-ids-in-second-converged-pass",
    "dispositions": [
      "in-domain",
      "out-of-domain"
    ],
    "totality": "exactly-one-final-disposition-per-sampling-frame-member",
    "inclusion": "all-and-only-in-domain-dispositions",
    "primaryScreen": "every-sampling-frame-member",
    "independentReview": {
      "primaryInDomain": "all",
      "primaryOutDomainRankInput": "utf8(open-autonomy.u1.out-domain-review.v1\\0)+utf8(github-node-id)",
      "hash": "sha256",
      "order": "ascending-unsigned-digest-bytes-then-ascending-utf8-node-id",
      "cardinality": "ceil(primary-out-domain-count/100)",
      "withoutReplacement": true
    },
    "conflictRule": "third-reviewer-adjudicates-every-disagreement",
    "postResultExclusion": "forbidden"
  },
  "evidence": {
    "retain": [
      "exact-response-body-bytes",
      "response-headers",
      "request-url",
      "observed-at"
    ],
    "bodyDigest": "sha256-exact-response-body-bytes",
    "acceptedResponse": {
      "httpStatus": 200,
      "contentTypePrefix": "application/json",
      "json": "object-with-nonnegative-integer-total_count-boolean-incomplete_results-and-items-array",
      "requiredItemFields": [
        "node_id",
        "full_name",
        "stargazers_count",
        "fork",
        "archived",
        "default_branch"
      ]
    },
    "primaryIdentity": "github-node-id",
    "secondaryIdentity": "case-insensitive-full-name-must-not-alias"
  },
  "invalidation": [
    "unpartitionable-overflow-leaf",
    "three-total-pass-attempts-exhausted",
    "no-two-pass-convergence-before-cutoff",
    "accepted-response-at-or-after-cutoff",
    "raw-body-digest-mismatch",
    "node-id-alias"
  ],
  "censusCutoff": "2026-07-22T23:59:59.999Z",
  "digest": "sha256:e2714f6e2c0fcd4c5f3c0bbb6a15da0ef56cd6b86596db5fcbe521bbab9f6189"
}
