{
  "name": "open-autonomy",
  "version": "0.4.2",
  "description": "Compile an agent profile onto a substrate (GitHub Actions or a local termfleet loop) — the open-autonomy CLI.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/volter-ai/open-autonomy.git"
  },
  "homepage": "https://github.com/volter-ai/open-autonomy#readme",
  "keywords": [
    "autonomy",
    "agents",
    "ai-agents",
    "github-actions",
    "scaffold",
    "cli"
  ],
  "type": "module",
  "packageManager": "bun@1.3.10",
  "engines": {
    "node": ">=22.18"
  },
  "bin": {
    "open-autonomy": "dist/cli.js",
    "oa": "dist/cli.js"
  },
  "files": [
    "dist/",
    "profiles/",
    "README.md",
    "LICENSE"
  ],
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "autonomy": "bun bin/open-autonomy.ts",
    "build": "bun scripts/build-cli.ts",
    "build:local-cli": "bun scripts/build-local-runner-cli.ts",
    "prepublishOnly": "bun run build && bun run check:release-consistency && bun run check:pack-smoke",
    "check:autonomy": "bunx tsc -p tsconfig.json",
    "check:core": "bun test packages/*/src/*.test.ts && bun scripts/generate-runtime-r9-evidence.ts --check",
    "check:bench-dev": "bun test bench/dev",
    "verify:external-campaign": "bun bench/dev/evidence/verify-external-campaign.ts",
    "acquire:r20": "bun bench/dev/evidence/r20-acquisition-cli.ts",
    "acquire:r27": "bun bench/dev/evidence/r27-acquisition-cli.ts",
    "acquire:r28": "bun bench/dev/evidence/r28-acquisition-cli.ts",
    "runtime-ledgers:init": "bun scripts/initialize-runtime-ledgers.ts",
    "organization-spec:fields": "bun scripts/generate-organization-field-semantics.ts",
    "organization-spec:schema": "bun scripts/generate-artifact-schema-corpus.ts",
    "conformance": "bun bin/autonomy-conformance.ts",
    "check:compile": "bun test bin/autonomy-compile.test.ts bin/autonomy-upgrade.test.ts bin/settings-merge.test.ts bin/ztrack-preset.test.ts bin/open-autonomy-help.test.ts && bun bin/check-compile.ts",
    "check:profiles": "bun bin/check-profiles.ts && bun test bin/lint-profile.test.ts",
    "check:policy-consumers": "bun test bin/check-policy-consumers.test.ts && bun bin/check-policy-consumers.ts",
    "check:setup-pack": "bun test bin/check-setup-pack.test.ts && bun bin/check-setup-pack.ts",
    "check:no-profile-branching": "bun test bin/check-no-profile-branching.test.ts && bun bin/check-no-profile-branching.ts",
    "check:ci-scaffold": "bun test bin/ensure-ci-workflow.test.ts",
    "check:recommend-cli": "bun test bin/recommend-profile.test.ts",
    "check:dispatch-audit": "bun test bin/dispatch-audit.test.ts",
    "check:doc-vars": "bun test bin/check-doc-vars.test.ts && bun bin/check-doc-vars.ts",
    "check:doctor": "bun test bin/doctor-checks.test.ts bin/doctor.test.ts",
    "check:install-detect": "bun test bin/install-detect.test.ts",
    "check:install-select": "bun test --timeout 30000 bin/install-select.test.ts",
    "check:install-direction": "bun test bin/install-direction.test.ts",
    "check:install-authorize": "bun test bin/install-authorize.test.ts",
    "check:install-execute": "bun test --timeout 30000 bin/install-execute.test.ts",
    "check:install-prove-advancing": "bun test bin/install-prove-advancing.test.ts",
    "check:install-handoff": "bun test --timeout 30000 bin/install-handoff.test.ts",
    "check:install": "bun test --timeout 60000 bin/install.test.ts",
    "check:runtime-sync": "bun bin/sync-runtime.ts --check",
    "check:dogfood": "bun bin/check-dogfood.ts",
    "check:provision": "bun bin/check-provision.ts",
    "check:preflight": "bun test bin/preflight.test.ts bin/collision-check.test.ts",
    "check:pack-smoke": "bun scripts/pack-smoke.ts",
    "check:release-consistency": "bun test bin/check-release.test.ts && bun bin/check-release.ts",
    "check": "bun run check:autonomy && bun run check:core && bun run check:bench-dev && bun run conformance exec && bun run check:runtime-sync && bun run check:compile && bun run check:profiles && bun run check:policy-consumers && bun run check:setup-pack && bun run check:no-profile-branching && bun run check:ci-scaffold && bun run check:recommend-cli && bun run check:dispatch-audit && bun run check:doc-vars && bun run check:preflight && bun run check:doctor && bun run check:install-detect && bun run check:install-select && bun run check:install-direction && bun run check:install-authorize && bun run check:install-execute && bun run check:install-prove-advancing && bun run check:install-handoff && bun run check:install && bun run check:dogfood && bun run check:provision && bun run check:supply-chain && bun run check:public-agent && bun run check:agent-proxy && bun run check:proof && bun run check:soc2-register && bun run check:release-consistency && bun run check:pack-smoke",
    "check:agent-proxy": "cd services/agent-model-proxy && bun install --frozen-lockfile && bun test test/*.test.ts && bunx tsc --noEmit",
    "check:public-agent": "bun test scripts/*.test.ts && bunx tsc --noEmit --skipLibCheck --moduleResolution Bundler --module ESNext --target ES2022 --types bun scripts/*.ts",
    "bench": "bun bin/bench.ts",
    "test": "bun run check:public-agent",
    "check:proof": "mkdir -p .agent-run/proof && bun scripts/open-autonomy-proof-audit.ts --roadmap .open-autonomy/roadmap.yml --ledger docs/PROOF_LEDGER.md --out .agent-run/proof/audit.json",
    "check:soc2-register": "bun profiles/soc2-baseline/scripts/soc2-register.ts verify && bun profiles/soc2-baseline/scripts/soc2-register.ts check",
    "check:supply-chain": "bun scripts/check-supply-chain.ts"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "1.17.5",
    "@slack/web-api": "7.17.0",
    "@types/bun": "^1.3.14",
    "@types/node": "^24.13.2",
    "@volter/twin": "0.1.0",
    "@volter/twin-slack": "0.1.0",
    "typescript": "^5.9.3",
    "yaml": "^2.9.0",
    "ztrack": "1.0.0"
  }
}
