{
  "name": "self-driving-repo-template",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.10",
  "scripts": {
    "check": "bun run check:public-agent",
    "check:public-agent": "bunx tsc --noEmit --skipLibCheck --moduleResolution Bundler --module ESNext --target ES2022 --types bun scripts/*.ts",
    "test": "bun run check:public-agent"
  },
  "dependencies": {
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^24.13.2",
    "typescript": "^5.9.3"
  }
}
