{
  "$comment": "Declarative provisioning manifest for the live open-autonomy testbed repo. Consumed by scripts/provision-target-repo.ts. Variable values are non-secret repo variables. NO admin secret is required: in-cell agents mint/revoke their model runs via the workflow's GitHub OIDC identity (id-token: write). Model/provider are intentionally NOT seeded: the compiled substrate defaults every agent to deepseek/deepseek-v4-flash, so a PUBLIC_AGENT_*_MODEL repo variable is only an optional per-repo override — the default lives in one place (the compile), not here.",
  "description": "open-autonomy live testbed",
  "private": true,
  "required_secrets": [],
  "variables": [
    { "name": "MODEL_PROXY_OIDC_AUDIENCE", "value": "volter-agent-model-proxy" },
    { "name": "MODEL_PROXY_URL", "value": "https://volter-agent-model-proxy.aaron-0ed.workers.dev" },
    { "name": "PUBLIC_AGENT_ALLOWED_PATHS", "value": "**" },
    { "name": "PUBLIC_AGENT_MAX_DEVELOP_ATTEMPTS", "value": "3" },
    { "name": "PUBLIC_AGENT_MAX_OPEN_AGENT_PRS", "value": "20" },
    { "name": "PUBLIC_AGENT_MAX_REQUESTS", "value": "200" },
    { "name": "PUBLIC_AGENT_MAX_USD_CENTS", "value": "500" },
    { "name": "PUBLIC_AGENT_PM_LIMIT", "value": "8" },
    { "name": "PUBLIC_AGENT_PM_MAX_USD_CENTS", "value": "25" },
    { "name": "PUBLIC_AGENT_REPO_PAUSED", "value": "false" },
    { "name": "PUBLIC_AGENT_REVIEW_MAX_USD_CENTS", "value": "50" },
    { "name": "PUBLIC_AGENT_STALE_NEEDS_INFO_MINUTES", "value": "10080" },
    { "name": "PUBLIC_AGENT_TRIAGE_MAX_USD_CENTS", "value": "25" }
  ],
  "labels": [
    { "name": "agent-paused", "color": "fbca04", "description": "Issue-level autonomy is paused" },
    { "name": "agent-repo-paused", "color": "b60205", "description": "Repo-level autonomy pause fallback" },
    { "name": "agent-blocked", "color": "d93f0b", "description": "Agent work is blocked" },
    { "name": "human-required", "color": "b60205", "description": "A maintainer decision is required" },
    { "name": "needs-info", "color": "fbca04", "description": "Waiting on clarifying information" },
    { "name": "duplicate", "color": "cfd3d7", "description": "Duplicate of another issue" },
    { "name": "spam", "color": "000000", "description": "Spam or abuse" },
    { "name": "manual-operator-test", "color": "0e8a16", "description": "Operator-control fixture; excluded from PM auto-develop" },
    { "name": "do-not-merge", "color": "b60205", "description": "Maintainer merge block" },
    { "name": "agent-audit-only", "color": "5319e7", "description": "Audit-only: PM/review may comment; develop blocked" },
    { "name": "agent-review-only", "color": "5319e7", "description": "Review-only: develop blocked; review allowed" },
    { "name": "agent-develop-only", "color": "5319e7", "description": "Develop+review allowed; merge gate stops for maintainer approval" },
    { "name": "origin:roadmap-planner", "color": "1d76db", "description": "Created by the roadmap planner" }
  ],
  "branch_protection": {
    "branch": "main",
    "required_checks": ["ci", "agent-review"]
  }
}
