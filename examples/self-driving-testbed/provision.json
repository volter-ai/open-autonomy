{
  "$comment": "Provisioning manifest for the self-driving testbed (a regex-playground web app). Constitution-only seed: the strategist generates the roadmap; the strategy reviewer ratifies it; no scenario issues are seeded. No per-repo secret is required — the workflows mint and revoke model-proxy runs via GitHub OIDC (the repo's public-agent workflow must be in the proxy's OIDC allowlist). Model/provider are intentionally NOT seeded: the compiled substrate defaults every agent to deepseek/deepseek-v4-flash, so a PUBLIC_AGENT_*_MODEL repo variable is only an optional per-repo override — the default lives in one place (the compile), not here.",
  "description": "open-autonomy self-driving testbed (regex playground; constitution-only seed)",
  "private": true,
  "required_secrets": [],
  "variables": [
    { "name": "MODEL_PROXY_OIDC_AUDIENCE", "value": "volter-agent-model-proxy" },
    { "name": "MODEL_PROXY_URL", "value": "https://volter-agent-model-proxy.aaron-0ed.workers.dev" },
    { "name": "PUBLIC_AGENT_ALLOWED_PATHS", "value": "**" },
    { "name": "PUBLIC_AGENT_MAX_DEVELOP_ATTEMPTS", "value": "3" },
    { "name": "PUBLIC_AGENT_MAX_OPEN_AGENT_PRS", "value": "20" },
    { "name": "PUBLIC_AGENT_MAX_REQUESTS", "value": "200" },
    { "name": "PUBLIC_AGENT_MAX_USD_CENTS", "value": "500" },
    { "name": "PUBLIC_AGENT_PM_LIMIT", "value": "8" },
    { "name": "PUBLIC_AGENT_PM_MAX_USD_CENTS", "value": "25" },
    { "name": "PUBLIC_AGENT_REPO_PAUSED", "value": "false" },
    { "name": "PUBLIC_AGENT_REVIEW_MAX_USD_CENTS", "value": "50" },
    { "name": "PUBLIC_AGENT_STALE_NEEDS_INFO_MINUTES", "value": "10080" },
    { "name": "PUBLIC_AGENT_STRATEGIST_MAX_USD_CENTS", "value": "150" },
    { "name": "PUBLIC_AGENT_STRATEGIST_MAX_ITEMS", "value": "3" },
