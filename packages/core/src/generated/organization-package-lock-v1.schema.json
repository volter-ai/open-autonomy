{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://open-autonomy.dev/schema/OrganizationPackageLock.json",
  "title": "Open Autonomy OrganizationPackageLock",
  "$ref": "#/$defs/OrganizationPackageLock",
  "$defs": {
    "OrganizationPackageLock": {
      "type": "object",
      "properties": {
        "schema": {
          "const": "autonomy.package-lock.v1"
        },
        "root": {
          "type": "string"
        },
        "registrySnapshot": {
          "$ref": "#/$defs/PackageDigest"
        },
        "packages": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/PackageLockEntry"
          }
        }
      },
      "required": [
        "schema",
        "root",
        "registrySnapshot",
        "packages"
      ],
      "additionalProperties": false
    },
    "PackageDigest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "PackageLockEntry": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^(?:[a-z0-9](?:[a-z0-9-]*[a-z0-9])?\\.)*[a-z0-9](?:[a-z0-9-]*[a-z0-9])?/(?!.*//)[a-z0-9](?:[a-z0-9._/-]*[a-z0-9])?$"
        },
        "version": {
          "type": "string",
          "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$"
        },
        "digest": {
          "$ref": "#/$defs/PackageDigest"
        },
        "registry": {
          "type": "string"
        },
        "mirrors": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "dependencies": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "signerKeys": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "name",
        "version",
        "digest",
        "registry",
        "dependencies"
      ],
      "additionalProperties": false
    }
  }
}
